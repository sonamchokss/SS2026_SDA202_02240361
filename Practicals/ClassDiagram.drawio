                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;\n@startuml\nskinparam backgroundColor #F9FAFB\nskinparam shadowing true\nskinparam roundcorner 15\nskinparam classAttributeIconSize 0\n\nskinparam class {\n    BackgroundColor #E3F2FD\n    BorderColor #1E88E5\n    ArrowColor #424242\n}\n\nskinparam package {\n    BackgroundColor #E8F5E9\n    BorderColor #43A047\n}\n\ntitle Class Diagram: Automated Programming Assignment Grading System\n\n&#39;======================\n&#39; USER PACKAGE\n&#39;======================\npackage \&quot;Users\&quot; {\n\n    abstract class User {\n        +userID: String\n        +name: String\n        +email: String\n    }\n\n    class Student {\n        +gitHubUsername: String\n        +submitAssignment()\n        +viewGrades()\n    }\n\n    class Professor {\n        +staffID: String\n        +setDeadline()\n        +defineCriteria()\n        +overrideGrade()\n    }\n\n    &#39; Generalization (Inheritance)\n    User &lt;|-- Student\n    User &lt;|-- Professor\n}\n\n&#39;======================\n&#39; CORE DOMAIN\n&#39;======================\npackage \&quot;Core System\&quot; {\n\n    class Assignment {\n        +assignmentID: String\n        +title: String\n        +dueDate: DateTime\n    }\n\n    class Submission {\n        +submissionID: String\n        +timestamp: DateTime\n        +repoURL: String\n        +rawScore: Float\n    }\n\n    class Grade {\n        +finalScore: Float\n        +feedback: String\n    }\n}\n\n&#39;======================\n&#39; SERVICES\n&#39;======================\npackage \&quot;Services\&quot; {\n\n    class GradingEngine &lt;&lt;Service&gt;&gt; {\n        +runTests()\n        +calculateScore()\n    }\n\n    class PlagiarismChecker &lt;&lt;Service&gt;&gt; {\n        +checkTurnItIn()\n        +compareSubmissions()\n    }\n\n    class LMSAdapter &lt;&lt;Service&gt;&gt; {\n        +syncToLMS()\n    }\n}\n\n&#39;======================\n&#39; RELATIONSHIPS (STRICT UML)\n&#39;======================\n\n&#39; Association (basic interaction)\nStudent \&quot;1\&quot; --&gt; \&quot;*\&quot; Submission : submits\nProfessor \&quot;1\&quot; --&gt; \&quot;*\&quot; Assignment : manages\n\n&#39; Aggregation (weak relationship)\nAssignment \&quot;1\&quot; o-- \&quot;*\&quot; Submission : groups\n\n&#39; Composition (strong ownership)\nSubmission \&quot;1\&quot; *-- \&quot;1\&quot; Grade : owns\n\n&#39; Dependency (temporary usage)\nSubmission ..&gt; GradingEngine : uses\nSubmission ..&gt; PlagiarismChecker : uses\n\nGrade ..&gt; LMSAdapter : exported via\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="92">
